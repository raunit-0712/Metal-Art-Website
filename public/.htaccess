# Aakriti Atelier Hostinger Shared Hosting .htaccess Configuration

# Enable Rewrite Engine
RewriteEngine On
RewriteBase /

# 1. Transparently serve directory index.html for requests without trailing slash
# Example: /about -> /about/index.html (URL in browser stays /about)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{DOCUMENT_ROOT}/$1/index.html -f
RewriteRule ^(.*[^/])$ $1/index.html [L]

# 2. Transparently serve directory index.html for requests with trailing slash
# Example: /about/ -> /about/index.html (URL in browser stays /about/)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{DOCUMENT_ROOT}/$1index.html -f
RewriteRule ^(.*)/$ $1index.html [L]

# 3. Serve Custom 404 Page
ErrorDocument 404 /404.html

# 4. Production Security Headers
<IfModule mod_headers.c>
  Header set X-Frame-Options "SAMEORIGIN"
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set X-XSS-Protection "1; mode=block"
  Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.googletagmanager.com https://aakritiatelier.in; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https://images.pexels.com https://aakritiatelier.in; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' https://www.google-analytics.com; frame-src 'self' https://www.google.com;"
</IfModule>
